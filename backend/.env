# Core
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:ENEGoSErYKjWRrccJQAGJlfviqFFOQRn@hopper.proxy.rlwy.net:28825/railway
# Comma-separated list; the backend prefers this over CORS_ORIGIN.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:5173
# Fallback single origin if you do not need multiple origins.
# CORS_ORIGIN=http://localhost:8080
JWT_SECRET=replace-with-a-strong-secret-min-32-characters
ENABLE_REQUEST_LOGGING=true

# Razorpay
# Choose mode: auto | test | live
# - auto: production prefers live keys, development prefers test keys
# - test/live: force that mode explicitly
RAZORPAY_MODE=auto

# Preferred explicit keys
RAZORPAY_TEST_KEY_ID=rzp_test_SaEe8a5hHi0oEa
RAZORPAY_TEST_KEY_SECRET=FXYxjo771kpovfpkQF13zgrG
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=replace-with-your-razorpay-live-secret

RAZORPAY_CURRENCY=INR

# Admin login throttling
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_LOCKOUT_MS=1800000

# Admin forgot-password OTP
ADMIN_PASSWORD_RESET_ALLOWED_PHONE=7981370664
ADMIN_PASSWORD_RESET_OTP_TTL_MS=600000
ADMIN_PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

# OTP provider: none | fast2sms
OTP_PROVIDER=fast2sms

# Fast2SMS (set OTP_PROVIDER=fast2sms to enable real SMS OTPs)
FAST2SMS_API_KEY=z2vYqJAgZDFmjMBaGNQ4I3SeR57LcO0xEsuW8htbTonPKXHp9womDi8YfR0c9J5v7Ms3LhOFKPNTkAqp
FAST2SMS_ENDPOINT=https://www.fast2sms.com/dev/bulkV2

# route=otp for simple OTP flow, route=dlt if your account requires DLT template mode
FAST2SMS_ROUTE=otp
# DLT fields not required for Quick SMS/OTP route
# FAST2SMS_SENDER_ID=
# FAST2SMS_TEMPLATE_ID=
# FAST2SMS_ENTITY_ID=
FAST2SMS_MESSAGE_TEMPLATE=Your SP Pickles admin OTP is {{OTP}}. It is valid for 10 minutes.
