# Backend Configuration
NODE_ENV=development
PORT=5000

# ⚠️ SECURITY NOTICE ⚠️
# This file should NOT be committed to version control
# Add .env to .gitignore to prevent credential exposure
# Database credentials are kept secure and not exposed here

# Database Configuration
# Using SQLite for development (sp-pickles.db)
DATABASE_PATH=./sp-pickles.db

# JWT Secret - Keep this secure!
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-here!

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Admin Login Security
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_LOCKOUT_MS=1800000

# API & Logging
API_PREFIX=/api
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ═════════════════════════════════════════════════════════════
# ADMIN CREDENTIALS (SECURE)
# ═════════════════════════════════════════════════════════════
# Email:    SPPICKLES
# Password: [HASHED IN DATABASE - NOT STORED IN PLAINTEXT]
#
# Login at: http://localhost:8080/admin/login
#
# ✓ Password is hashed using scrypt algorithm
# ✓ Not visible in frontend code
# ✓ Rate-limited after 5 failed attempts
# ✓ 30-minute lockout after max attempts
# ═════════════════════════════════════════════════════════════
