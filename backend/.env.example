# Backend Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (supports both PostgreSQL and SQLite)
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/sp_pickles

# For SQLite (development):
DATABASE_PATH=./sp-pickles.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-here!

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Admin Login Security
# Max login attempts before lockout
ADMIN_LOGIN_MAX_ATTEMPTS=5
# Time window for tracking attempts (in milliseconds, default: 15 min)
ADMIN_LOGIN_WINDOW_MS=900000
# Lockout duration after max attempts (in milliseconds, default: 30 min)
ADMIN_LOGIN_LOCKOUT_MS=1800000

# API Configuration
API_PREFIX=/api
API_REQUEST_TIMEOUT_MS=30000

# Logging Configuration
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security Configuration
# Set to 'true' to enable HTTPS redirect
REQUIRE_HTTPS=false
# Maximum body size (in bytes, default: 1MB)
MAX_BODY_SIZE=1000000
