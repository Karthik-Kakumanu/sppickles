# Core
NODE_ENV=development
PORT=5000
DATABASE_URL=postgres://username:password@localhost:5432/sppickles
# Comma-separated list; the backend prefers this over CORS_ORIGIN.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:5173
# Fallback single origin if you do not need multiple origins.
# CORS_ORIGIN=http://localhost:8080
JWT_SECRET=replace-with-a-strong-secret-min-32-characters
ENABLE_REQUEST_LOGGING=true

# Razorpay
# Choose mode: auto | test | live
# - auto: production prefers live keys, development prefers test keys
# - test/live: force that mode explicitly
RAZORPAY_MODE=auto

# Preferred explicit keys
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=replace-with-your-razorpay-test-secret
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=replace-with-your-razorpay-live-secret

# Legacy fallback (optional). Used only if explicit mode keys are not set.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

RAZORPAY_CURRENCY=INR

# Admin login throttling
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_LOCKOUT_MS=1800000
