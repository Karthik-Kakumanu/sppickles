{
  "name": "sp-pickles",
  "private": true,
  "description": "SP Traditional Pickles - Premium Homemade Pickles Storefront",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host localhost --port 8080",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "vite build",
    "build:backend": "echo 'Backend does not require building'",
    "preview": "vite preview",
    "install:all": "npm install && cd backend && npm install",
    "lint": "eslint .",
    "type-check": "tsc -b"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  }
}
